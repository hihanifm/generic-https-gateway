:{$EXTERNAL_HTTP_PORT} {
	log {
		output stderr
		level INFO
	}

	# Route requests under /service1 to app1.
	@service1 path /service1*
	handle @service1 {
		uri strip_prefix /service1
		reverse_proxy app1:{$APP1_PORT}
	}

	# Route requests under /service2 to app2.
	@service2 path /service2*
	handle @service2 {
		uri strip_prefix /service2
		reverse_proxy app2:{$APP2_PORT}
	}

	# Host-process upstream (not a Docker service on this compose network).
	# WNM_UPSTREAM is host:port as seen from the gateway container (e.g. host.docker.internal:18081).
	# WNM_HOST_HEADER is the Host header the upstream expects (dev servers often reject the gateway's Host).
	@wnm path /wnm /wnm/*
	handle @wnm {
		uri strip_prefix /wnm
		reverse_proxy {$WNM_UPSTREAM} {
			header_up Host {$WNM_HOST_HEADER}
		}
	}

	# Hub landing page (static).
	root * /srv

	# Keep the service catalog fresh to reduce config drift confusion.
	@hubConfig path /services.yml
	header @hubConfig Cache-Control "no-store"

	# Cache static assets briefly for snappier reloads.
	@hubAssets path *.css *.js
	header @hubAssets Cache-Control "public, max-age=3600"

	@hubHtml path / /index.html
	header @hubHtml Cache-Control "no-store"

	file_server
}
